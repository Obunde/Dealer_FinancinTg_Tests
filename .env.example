# Copy to .env and fill in. .env is gitignored; this example is committed.
# Keys map to config keys automatically (bank.maker.username -> BANK_MAKER_USERNAME).
# Resolution order: -D system property > shell env > .env > config.properties

# ---- Platform URL (all actors use the same app) ----
APP_URL=https://scf.example.com
SYSTEMADMIN_URL=https://scf.example.com
BANK_URL=https://scf.example.com
ANCHOR_URL=https://scf.example.com
DEALER_URL=https://scf.example.com

# ---- Platform Admin (Emtech) ----
SYSTEMADMIN_MAKER_USERNAME=admin.maker@example.com
SYSTEMADMIN_MAKER_PASSWORD=
SYSTEMADMIN_CHECKER_USERNAME=admin.checker@example.com
SYSTEMADMIN_CHECKER_PASSWORD=

# ---- FI / Bank (Faulu) ----
BANK_MAKER_USERNAME=fi.maker@example.com
BANK_MAKER_PASSWORD=
BANK_CHECKER_USERNAME=fi.checker@example.com
BANK_CHECKER_PASSWORD=

# ---- Anchor (created during the E2E flow; fill once a stable one exists) ----
ANCHOR_MAKER_USERNAME=
ANCHOR_MAKER_PASSWORD=
ANCHOR_CHECKER_USERNAME=
ANCHOR_CHECKER_PASSWORD=

# ---- Dealer (created during the E2E flow; fill once a stable one exists) ----
DEALER_MAKER_USERNAME=
DEALER_MAKER_PASSWORD=
DEALER_CHECKER_USERNAME=
DEALER_CHECKER_PASSWORD=

# ---- API helper (optional) ----
API_BASE_URL=
API_TOKEN=
