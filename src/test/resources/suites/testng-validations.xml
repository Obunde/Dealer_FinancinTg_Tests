<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- All negative/UI validation tests across every actor. -->
<suite name="SCF Validations Only" parallel="tests" thread-count="4">
    <listeners>
        <listener class-name="com.scf.base.RetryTransformer"/>
    </listeners>
    <test name="All Validations">
        <groups>
            <run>
                <include name="validation"/>
            </run>
        </groups>
        <packages>
            <package name="com.scf.tests.*"/>
        </packages>
    </test>
</suite>
